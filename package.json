{
  "name": "md2pdf",
  "displayName": "md2pdf",
  "description": "Export Markdown to styled HTML and PDF with inline chart generation, GitHub alerts, math, and Mermaid support",
  "version": "0.1.0",
  "publisher": "dcuccia",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "keywords": [
    "markdown",
    "pdf",
    "html",
    "chart",
    "mermaid",
    "export",
    "converter"
  ],
  "activationEvents": [],
  "main": "./out/src/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcuccia/md2pdf-vscode"
  },
  "contributes": {
    "commands": [
      {
        "command": "md2pdf.exportPdf",
        "title": "md2pdf: Export as PDF"
      },
      {
        "command": "md2pdf.exportHtml",
        "title": "md2pdf: Export as HTML"
      },
      {
        "command": "md2pdf.exportBoth",
        "title": "md2pdf: Export as HTML + PDF"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .md",
          "command": "md2pdf.exportPdf",
          "group": "md2pdf@1"
        },
        {
          "when": "resourceExtname == .md",
          "command": "md2pdf.exportHtml",
          "group": "md2pdf@2"
        },
        {
          "when": "resourceExtname == .md",
          "command": "md2pdf.exportBoth",
          "group": "md2pdf@3"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .md",
          "command": "md2pdf.exportPdf",
          "group": "md2pdf@1"
        },
        {
          "when": "resourceExtname == .md",
          "command": "md2pdf.exportHtml",
          "group": "md2pdf@2"
        },
        {
          "when": "resourceExtname == .md",
          "command": "md2pdf.exportBoth",
          "group": "md2pdf@3"
        }
      ]
    },
    "configuration": {
      "title": "md2pdf",
      "properties": {
        "md2pdf.toolPath": {
          "type": "string",
          "default": "",
          "description": "Path to the md2pdf repository root. If empty, uses the bundled pipeline scripts."
        },
        "md2pdf.theme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "academic",
            "minimal"
          ],
          "description": "CSS theme for HTML/PDF output."
        },
        "md2pdf.outputDirectory": {
          "type": "string",
          "default": "",
          "description": "Output directory for generated files. If empty, outputs next to the source file."
        },
        "md2pdf.imageScale": {
          "type": "number",
          "default": 350,
          "description": "Default image height scale for SVG charts in PDF output."
        },
        "md2pdf.browserPath": {
          "type": "string",
          "default": "",
          "description": "Path to Chrome/Edge/Chromium executable for PDF rendering. If empty, auto-detects system browser."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle-pipeline && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "bundle-pipeline": "node scripts/bundle-pipeline.js"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.56.0",
    "mocha": "^10.3.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "puppeteer-core": "^24.39.0"
  }
}
